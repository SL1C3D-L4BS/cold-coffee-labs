{
  "$schema": "https://github.com/affaan-m/everything-claude-code/schemas/agentshield.schema.json",
  "policy_version": "1.2",
  "description": "AgentShield config for Greywater / Sacrilege (ADR-0119, ADR-0120).",
  "blocked_paths": [
    "assets/ai/**/*.bin",
    "bld/bld-governance/policy/**",
    "engine/core/crypto/**",
    ".cursor/agentshield.json",
    ".github/workflows/**"
  ],
  "require_adr_reference_for": [
    "docs/01_CONSTITUTION_AND_PROGRAM.md",
    "docs/02_ROADMAP_AND_OPERATIONS.md",
    "docs/10_APPENDIX_ADRS_AND_REFERENCES.md",
    "CMakePresets.json"
  ],
  "exempt_paths_for_volume_caps": [
    "third_party/**",
    ".cursor/**",
    ".codex/**",
    ".opencode/**",
    ".gemini/**",
    ".kiro/**",
    ".trae/**",
    ".agents/**",
    "graphify-out/**"
  ],
  "max_files_per_session": 200,
  "max_lines_per_session": 15000,
  "enforce_commit_trailer": true,
  "commit_trailer_key": "Agent-Session",
  "waiver_trailer_key": "Waiver",
  "hook_budget_ms": 250,
  "graphify_required": true,
  "graphify_graph_path": "graphify-out/graph.json",
  "deny_on_missing_graph": false,
  "adr_links": ["ADR-0118", "ADR-0119", "ADR-0120"]
}
