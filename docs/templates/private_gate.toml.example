# Copy to %APPDATA%\GreywaterEditor\private_gate.toml (Windows) or
# ~/.config/greywater_editor/private_gate.toml (Linux).
# Do NOT commit the real file — keep it gitignored locally.
#
# Option A — plaintext (local machine only):
# user = "you"
# password_plain = "change-me"
#
# Option B — SHA-256 of UTF-8 string (salt + password), 64 lowercase hex chars:
# user = "you"
# salt = "random-salt-string"
# password_sha256_hex = "................................"

user = "studio"
password_plain = "change-me"
