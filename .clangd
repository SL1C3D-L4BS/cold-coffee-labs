# Greywater — clangd / IDE IntelliSense
#
# CMake exports compile_commands.json under build/<preset>/ (not at repo root).
# Pointing clangd at that database is required so TU flags match clang-cl:
# -IC:/.../cold-coffee-labs, doctest, imgui, bld headers, etc.
#
# Windows: `cmake --preset dev-win` then reload the window (or restart clangd).
# Linux: change CompilationDatabase below to `build/dev-linux`, or symlink
#   build/<preset>/compile_commands.json → ./compile_commands.json at the root.

If:
  PathMatch: .*
CompileFlags:
  CompilationDatabase: build/dev-win
  Add:
    # Fallback when a file has no compile_commands entry yet.
    - -std=c++23
    - -I.
    - -Ibuild/dev-win/_deps/glm-src
    - -Ibuild/dev-linux/_deps/glm-src
