# Build trees (CMake preset output dir).
/build/
/out/
/cmake-build-*/

# Cargo.
/target/
/bld/target/
**/target/
Cargo.lock
!bld/Cargo.lock

# CPM cache.
/cpm_cache/
.cpm/

# IDE / editor.
/.vs/
/.vscode/
/.idea/
/.cache/
*.swp
*.swo
*~

# Compiler / sanitizer artefacts.
*.o
*.obj
*.lib
*.a
*.pdb
*.dll
*.so
*.dylib
*.exe
compile_commands.json

# Content source (per docs/10 §4 — tracked assets live in /assets, sources under /content are gitignored).
/content/
!/content/.gitkeep

# Franchise game content/ mirrors the same rule: local pulls (e.g. AmbientCG) live under content/textures/.
franchises/**/content/textures/

# Python bytecode caches (local tooling).
__pycache__/
*.py[cod]

# Ephemeral.
*.log
.env
.env.local
*.key
*.pem
*.p12
.DS_Store
Thumbs.db

# Machine-side diagnostics (audit-2026-04-20 P4.1): dxdiag dumps and the
# accidental 0.txt land that leaked a machine GUID before. Never commit.
0.txt
DxDiag*.txt
dxdiag*.txt

# Repo-root `bin/` is a scratch directory for local smoke runs. CI/release
# artifacts live under build/<preset>/bin/ and are already covered by /build/.
/bin/

# Phase 15 — local saves / telemetry / cloud (never commit).
*.gwsave
**/sentry-db/
**/cloud_saves/
telemetry_queue.sqlite
tele.dsn.key
dsar_out/

# Graphify (ADR-0118) — commit graph.json + GRAPH_REPORT.md; cache + HTML +
# cost / manifest files are regenerated on every `graphify update .`.
graphify-out/cache/
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/graph.html
graphify-out/memory/
graphify-out/raw/
