{
  "$schema": "../../assets/schemas/mod_manifest.schema.json",
  "mod_id": "example_mod",
  "display_name": "Example Mod",
  "description": "Scaffold mod demonstrating the mod SDK surface (Part C §22, ADR-0115b).",
  "author": "Cold Coffee Labs",
  "version": "0.1.0",
  "engine_min_version": "0.18.0",
  "engine_max_version": "0.29.99",
  "api_level": 1,
  "sandbox": {
    "filesystem_jail": "mods/example_mod/",
    "allow_network": false,
    "allow_steam_api": false,
    "bld_tool_surface": "read_only"
  },
  "entry_points": [
    {
      "kind": "dll",
      "path": "mod_main.dll",
      "linux_path": "libmod_main.so"
    }
  ],
  "content": {
    "materials": [],
    "encounters": [],
    "dialogue": []
  },
  "signing": {
    "required_in_release": true,
    "ed25519_public_key": null,
    "ed25519_signature":  null
  }
}
